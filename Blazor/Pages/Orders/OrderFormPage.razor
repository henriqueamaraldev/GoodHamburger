@page "/orders/new"
@page "/orders/{Id:guid}/edit"
@rendermode InteractiveServer
@inject IMenuService MenuService
@inject IOrderService OrderService
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Editar pedido" : "Novo pedido") — Good Hamburger</PageTitle>

<div class="space-y-6 max-w-2xl">
    <div class="flex items-center gap-3">
        <a href="/orders" class="text-gray-400 hover:text-gray-600 transition-colors">← Voltar</a>
        <h1 class="text-2xl font-bold text-gray-800">
            @(_isEdit ? "Editar pedido" : "Novo pedido")
        </h1>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <ErrorAlert Message="@_error" />

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
            <div>
                <p class="text-sm font-semibold text-gray-700 mb-3">Selecione os itens</p>
                <div class="space-y-2">
                    @foreach (var item in _menuItems)
                    {
                        <label class="flex items-center justify-between p-3 rounded-lg border cursor-pointer transition-colors
                                      @(_selected.Contains(item.Id) ? "border-brand-400 bg-brand-50" : "border-gray-200 hover:border-gray-300")">
                            <div class="flex items-center gap-3">
                                <input type="checkbox"
                                       checked="@_selected.Contains(item.Id)"
                                       @onchange="() => Toggle(item.Id)"
                                       class="accent-brand-600 w-4 h-4" />
                                <span class="text-sm font-medium text-gray-800">@item.Name</span>
                            </div>
                            <span class="text-sm text-brand-600 font-semibold">R$ @item.Price.ToString("F2")</span>
                        </label>
                    }
                </div>
            </div>

            @if (_preview is not null)
            {
                <div class="rounded-lg bg-gray-50 border border-gray-200 p-4 text-sm space-y-1">
                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal</span>
                        <span>R$ @_preview.Subtotal.ToString("F2")</span>
                    </div>
                    @if (_preview.Discount > 0)
                    {
                        <div class="flex justify-between text-green-600 font-medium">
                            <span>Desconto</span>
                            <span>− R$ @_preview.Discount.ToString("F2")</span>
                        </div>
                    }
                    <div class="flex justify-between text-gray-900 font-bold text-base border-t border-gray-200 pt-2 mt-2">
                        <span>Total</span>
                        <span>R$ @_preview.Total.ToString("F2")</span>
                    </div>
                </div>
            }

            <button @onclick="SubmitAsync"
                    disabled="@(_selected.Count == 0 || _submitting)"
                    class="w-full bg-brand-600 hover:bg-brand-700 disabled:opacity-50 disabled:cursor-not-allowed
                           text-white font-semibold py-2.5 rounded-lg transition-colors">
                @(_submitting ? "Salvando…" : (_isEdit ? "Salvar alterações" : "Criar pedido"))
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private IEnumerable<MenuItemModel> _menuItems = [];
    private HashSet<Guid> _selected = new();
    private OrderModel? _preview;
    private bool _loading = true;
    private bool _submitting;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _menuItems = await MenuService.GetMenuAsync();

            if (_isEdit)
            {
                var order = await OrderService.GetByIdAsync(Id!.Value);
                if (order is not null)
                    _selected = order.Items.Select(i => i.MenuItemId).ToHashSet();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }

        UpdatePreview();
    }

    private void Toggle(Guid id)
    {
        if (!_selected.Add(id))
            _selected.Remove(id);
        UpdatePreview();
    }

    private void UpdatePreview()
    {
        if (_selected.Count == 0) { _preview = null; return; }

        var items = _menuItems.Where(m => _selected.Contains(m.Id)).ToList();
        var subtotal = items.Sum(i => i.Price);

        bool hasSandwich = items.Any(i => i.IsSandwich);
        bool hasFries    = items.Any(i => i.SideType == "Fries");
        bool hasSoda     = items.Any(i => i.SideType == "Soda");

        decimal rate = (hasSandwich, hasFries, hasSoda) switch
        {
            (true, true, true)  => 0.20m,
            (true, false, true) => 0.15m,
            (true, true, false) => 0.10m,
            _                   => 0m
        };

        var discount = Math.Round(subtotal * rate, 2);
        _preview = new OrderModel(Guid.Empty, "Pending", subtotal, discount, subtotal - discount, []);
    }

    private async Task SubmitAsync()
    {
        _submitting = true;
        _error = null;
        try
        {
            var request = new OrderRequestModel { MenuItemIds = _selected.ToList() };

            if (_isEdit)
                await OrderService.UpdateAsync(Id!.Value, request);
            else
                await OrderService.CreateAsync(request);

            Nav.NavigateTo("/orders");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
